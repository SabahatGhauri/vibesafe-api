{
  "functions": {
    "api/launch-check.js": { "maxDuration": 60 },
    "api/monitor-scan.js": { "maxDuration": 60 },
    "api/scan-followup.js": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/scan-followup", "schedule": "0 9 * * *" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ]
}
